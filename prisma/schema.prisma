// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js" 
}

datasource db {
  provider = "postgresql"
}

enum User_States {
  DISCONNECTED
  CONNECTED
  UNKNOWN
  IN_GAME
}

enum Friendship_States {
  PENDING
  FRIEND
  BLOCKED
}

enum Rarity {
  COMMON
  UNCOMMON
  SPECIAL
  EPIC
  LEGENDARY
}

enum Purchase_Type {
  SINGLE_CARD
  CARD_PACK
  COLLECTION
  BOARD
}

enum Board_Type {
  CLASSIC
  NEON                  // Añadir los que comunique el frontend (He sacado el NEON del mockup)
  STELLAR_GALAXY
}

model User {
  id_user        Int         @id @default(autoincrement())
  username       String      @unique
  email          String      @unique
  password       String
  coins          Int         @default(0)
  exp_level      Int         @default(0)
  progress_level Int         @default(0)
  state          User_States @default(UNKNOWN)
  personal_state String? // Para añadir 
  active_board_id   Int?        // Campo nuevo: ID del tablero seleccionado
  active_board      Board?      @relation("ActiveBoard", fields: [active_board_id], references: [id_board])

  my_boards      UserBoard[]
  my_cards       UserCard[]
  my_deck        Deck[]
  purchases      PurchaseHistory[]
  games          UserGameStats[]

  friends_sent     Friendships[] @relation("Enviadas")
  friends_received Friendships[] @relation("Recibidas")
}

model Board {
  id_board    Int      @id @default(autoincrement())
  name        String   @unique
  description String
  price       Int

  owners      UserBoard[]
  active_in_users User[] @relation("ActiveBoard")

  purchases   PurchaseHistory[]
}

model UserBoard {
  id_user_board Int      @id @default(autoincrement())
  id_user       Int
  id_board      Int

  user  User  @relation(fields: [id_user], references: [id_user])
  board Board @relation(fields: [id_board], references: [id_board])

  @@index([id_user])
  @@unique([id_user, id_board]) // Un usuario no puede tener el mismo tablero repetido
}

model PurchaseHistory {
  id_purchase   Int           @id @default(autoincrement())
  id_user       Int
  purchase_type Purchase_Type
  coins_spent   Int
  purchased_at  DateTime      @default(now())
 
  // Si es un tablero, se conecta aquí
  board_id      Int?
  board         Board?        @relation(fields: [board_id], references: [id_board])

  // Si son cartas (packs/colecciones/sueltas), se conectan aquí
  cards         PurchaseHistoryCard[]

  user          User          @relation(fields: [id_user], references: [id_user])
}

// Tabla intermedia para saber qué cartas se compraron en esa transacción
model PurchaseHistoryCard {
  id_purchase Int
  id_card     Int
  purchase    PurchaseHistory @relation(fields: [id_purchase], references: [id_purchase])
  card        Cards           @relation(fields: [id_card], references: [id_card])

  @@id([id_purchase, id_card])
}

model UserCard {
  id_user_card Int @id @default(autoincrement())
  id_user      Int
  id_card      Int

  user User @relation(fields: [id_user], references: [id_user])

  // Un UserCard (una carta física del usuario) puede estar en varios mazos
  card       Cards      @relation(fields: [id_card], references: [id_card])
  deck_cards DeckCard[]

  @@index([id_user])
}

model Deck {
  id_deck Int    @id @default(autoincrement())
  name    String @default("Nuevo Mazo")
  id_user Int
  user    User   @relation(fields: [id_user], references: [id_user])

  // Las cartas que componen este mazo específico
  cards DeckCard[]
}

// Tabla intermedia para que una carta de mi inventario esté en un mazo
model DeckCard {
  id_deck      Int
  id_user_card Int

  deck      Deck     @relation(fields: [id_deck], references: [id_deck])
  user_card UserCard @relation(fields: [id_user_card], references: [id_user_card])

  @@id([id_deck, id_user_card])
}

model Cards {
  id_card       Int        @id @default(autoincrement())
  title         String     @unique
  rarity        Rarity     @default(COMMON)
  url_image     String     @default("")
  
  id_collection Int
  collection    Collection @relation(fields: [id_collection], references: [id_collection])

  // Relación con los inventarios de los usuarios
  owners UserCard[]

  // Relación con el historial de compras
  purchases PurchaseHistoryCard[]
}

model Collection {
  id_collection Int     @id @default(autoincrement())
  name          String  @unique
  description   String?
  releaseDate   DateTime @default(now())
  cards         Cards[]
}

model Friendships {
  id_user_1 Int
  id_user_2 Int

  user_1 User @relation("Enviadas", fields: [id_user_1], references: [id_user])
  user_2 User @relation("Recibidas", fields: [id_user_2], references: [id_user])

  state          Friendship_States
  beggining_date DateTime          @default(now())

  @@id([id_user_1, id_user_2])
}

model Games_log {
  id_game        Int      @id @default(autoincrement())
  duration       Int
  beggining_date DateTime @default(now())

  participants UserGameStats[]
}

model UserGameStats {
  points Int // Los puntos de ESTE usuario en ESTA partida
  place  Int // El puesto de ESTE usuario en ESTA partida

  id_user Int
  id_game Int
  user    User      @relation(fields: [id_user], references: [id_user])
  game    Games_log @relation(fields: [id_game], references: [id_game])

  @@id([id_user, id_game]) // Clave primaria compuesta
}