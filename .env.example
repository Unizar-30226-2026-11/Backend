PORT=3000

# Valores usados por docker-compose.yml para PostgreSQL
DB_USER="user"
DB_PASSWORD="pass"
DB_NAME="mydb"
DB_PORT=5432

# Conexión local a PostgreSQL levantado por Docker Compose
DATABASE_URL="postgresql://user:pass@localhost:5432/mydb?schema=public"

# Redis del docker-compose no usa contraseña por defecto
REDIS_URL="redis://localhost:6379"

JWT_SECRET="una_clave_muy_segura_y_larga"
AES_KEY="32_characters_long_key_for_aes_256"